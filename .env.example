# ============================================================================
# 2Africa AgriOS - Environment template for production deployment.
# Copy to .env.prod and fill real secrets. NEVER commit .env.prod.
# ============================================================================

# ----- Image tags (CI/CD) -----
# Pin to a specific :sha for predictable rollouts, or use :latest for the head of main.
# bin/deploy.sh updates these for you.
BACKEND_IMAGE=ghcr.io/2africaai/2africa-agrios-backend:latest
FRONTEND_IMAGE=ghcr.io/2africaai/2africa-agrios-frontend:latest

# ----- Spring profile -----
SPRING_PROFILES_ACTIVE=prod

# ----- Database (MySQL) -----
DB_HOST=mysql
DB_PORT=3306
DB_NAME=toafrica_agrios
DB_USER=agrios
DB_PASSWORD=CHANGE_ME_strong_db_password_here
# Root password for the mysql container (only when running mysql via compose/k8s in-cluster)
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password
DB_POOL_MAX=30
DB_POOL_MIN=5

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_DB=0

# ----- JWT (must be at least 64 chars for HS512) -----
JWT_SECRET=CHANGE_ME_generate_a_64plus_char_random_string_with_openssl_rand_base64_64

# ----- Object storage (MinIO in-cluster, or S3/OSS in cloud) -----
# Internal endpoint that backend uses to reach storage:
OSS_ENDPOINT=http://minio:9000
# Public endpoint that browser uses to download files via presigned URLs:
OSS_PUBLIC_ENDPOINT=https://files.farm.example.com
OSS_AK=CHANGE_ME_minio_access_key
OSS_SK=CHANGE_ME_minio_secret_key
OSS_BUCKET=2africa-agrios
# MinIO root creds (only when running minio via compose/k8s in-cluster):
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_root_password

# ----- CORS (comma-separated, no spaces) -----
CORS_ALLOWED_ORIGINS=https://farm.example.com

# ----- Frontend public URL (baked into Vite build at image build time) -----
# Used by the trace QR code generator and external links.
VITE_PUBLIC_BASE_URL=https://farm.example.com
