# ============================================================
# Albert's Farm - Project Root .gitignore
# 子目录 backend/ 和 frontend/ 各有自己的 .gitignore,这里只补充根级别
# ============================================================

# 操作系统垃圾文件
.DS_Store
Thumbs.db
Desktop.ini

# 通用编辑器
.idea/
.vscode/
*.swp
*.swo
*~

# 临时文件
*.bak
*.tmp
*.log

# Docker 数据卷如果有人配置成本地路径
docker-data/

# Environment files (anything containing secrets) - DO NOT COMMIT
.env
.env.local
.env.*.local
.env.prod
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Build artefacts
target/
dist/
build/
*.jar
!**/maven-wrapper.jar
*.war
*.ear

# Backups and database dumps
backups/
*.sql.gz
*.dump

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs and PID
*.log
*.pid

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
.npm/

# Python (for tooling scripts)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OpenAPI tooling
openapi-generator/
.generated/

# AI-assistant scratch files
.claude/
.cursor/
.aider*
