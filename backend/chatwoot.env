# ============================================================================
# Chatwoot environment file (Sprint 40, dev defaults)
# ----------------------------------------------------------------------------
# Source these from docker-compose.yml via env_file. NOT committed for prod —
# add backend/chatwoot.env to backend/.gitignore there (or move secrets to env
# vars when deploying for real customers).
# ============================================================================

# Required identity
SECRET_KEY_BASE=replace-this-with-openssl-rand-base64-64-in-prod-aaaaaaaaaaaaaaa
FRONTEND_URL=http://localhost:3000

# DB
POSTGRES_HOST=chatwoot-postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=chatwoot123

# Redis
REDIS_URL=redis://:chatwootredis123@chatwoot-redis:6379

# Rails
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
ENABLE_ACCOUNT_SIGNUP=true
FORCE_SSL=false

# Mailer (dev: send to stdout; configure SMTP for real outbound)
MAILER_SENDER_EMAIL=AgriOS Service <noreply@agrios.local>
SMTP_DOMAIN=agrios.local
SMTP_ADDRESS=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# Storage (use local disk in dev; switch to S3/MinIO in prod)
ACTIVE_STORAGE_SERVICE=local

# Default account name shown at first login
INSTALLATION_NAME=2Africa AgriOS Service

# Sprint 40e: allow AgriOS frontend (Vue dev :5173 + prod :8080) to iframe Chatwoot.
# Comma-separated list of allowed origins (no trailing slash). Whitelisting these
# overrides Chatwoot's default X-Frame-Options=SAMEORIGIN for these parents only.
FRAME_ANCESTORS=http://localhost:5173,http://localhost:8080

# ============================================================================
# Optional: Microsoft 365 / Google OAuth for Email inboxes.
# When unset (default), Chatwoot UI shows the Microsoft + Google buttons as
# greyed-out. Without these, the only Email inbox path is "Other Providers"
# (raw IMAP/SMTP credentials).
#
# To enable Microsoft OAuth:
#   1. Azure Portal -> App registrations -> New registration
#      Name: 2Africa Chatwoot
#      Redirect URI (Web): http://localhost:3000/omniauth/microsoft_office_oauth2/callback
#   2. Copy "Application (client) ID" -> AZURE_APP_ID
#   3. Certificates & secrets -> New client secret -> AZURE_APP_SECRET
#   4. API permissions: IMAP.AccessAsUser.All, SMTP.Send, offline_access, openid
#   5. Uncomment + fill below, restart chatwoot-web
#
# AZURE_APP_ID=...
# AZURE_APP_SECRET=...
#
# To enable Google OAuth:
#   1. Google Cloud Console -> Credentials -> OAuth client ID -> Web app
#      Redirect URI: http://localhost:3000/omniauth/google_oauth2/callback
#   2. Enable Gmail API
#   3. Uncomment + fill below, restart chatwoot-web
#
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...

# ============================================================================
# AI Agent — Sprint 40f will set these after we plug in Claude
# ============================================================================
# CAPTAIN_OPEN_AI_API_KEY=  # if using OpenAI
# Claude integration is configured via Chatwoot's "Agent Bots" → Anthropic
# integration, NOT via env var. We'll do this in UI/API during Sprint 40f.
